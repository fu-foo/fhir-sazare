        "path": "MedicationAdministration.dosage.rate[x]",
        "sliceName": "rateRatio",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Ratio",
            "profile": [
              "http://jpfhir.jp/fhir/core/StructureDefinition/JP_MedicationRatio_DosePerPeriod"
            ]
          }
        ]
      },
